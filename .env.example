# Copy this to .env and fill in values. .env is gitignored.

# Weights & Biases (optional — only if WANDB_MODE=online)
WANDB_API_KEY=
WANDB_PROJECT=nba-sim
WANDB_ENTITY=
WANDB_MODE=offline  # offline | online | disabled

# Local storage roots (absolute or relative to repo root)
NBA_SIM_DATA_DIR=./data
NBA_SIM_MODEL_DIR=./models
NBA_SIM_CACHE_DIR=./data/raw/.cache

# nba_api politeness
NBA_API_REQUEST_TIMEOUT=30
NBA_API_MIN_DELAY_SECONDS=0.6

# Basketball Reference fallback
BREF_USER_AGENT="nba-sim research crawler (contact: you@example.com)"
BREF_MIN_DELAY_SECONDS=3.0

# Logging
LOG_LEVEL=INFO
